.DS_Store
__pycache__/
*.pyc
node_modules/
sessions/
*.tmp
.worktrees/

# Test + coverage artifacts (generated by vitest / pytest)
coverage/
coverage-*.xml
.coverage
.pytest_cache/
.venv/
# uv test-run lockfile (regenerated from skills/skill-comply/pyproject.toml by `uv run`).
# Force-add it if you want reproducible test deps: git add -f skills/skill-comply/uv.lock
skills/skill-comply/uv.lock

# Local gate state (transient, session-scoped)
.claude/*.local
.claude/*.local.*
.claude/litmus-state.md
.claude/bypass-log.jsonl
.claude/review-metrics.jsonl
.claude/*.log
.claude/.gate-block-count.local
.claude/.impl-gate-block-count.local
.claude/_backstop/

# Claude workspace artifacts
.claude/worktrees/
# AGENTS.md files are agent dev-instructions by default (the repo root file and
# each vendored skill's upstream dev-meta copy) — keep them out of git.
AGENTS.md
# Exceptions: vendored skill *content guides* that a SKILL.md explicitly points to
# MUST ship so the plugin stays self-contained. These negations also override the
# user's global core.excludesFile `AGENTS.md` rule (repo .gitignore wins).
!skills/vercel-react-best-practices/AGENTS.md
!skills/vercel-composition-patterns/AGENTS.md
!skills/vercel-react-native-skills/AGENTS.md

# Review artifacts: prompt dumps, verdict JSON, and review-loop state. Machine
# output — regenerable, and worthless once the review has landed.
docs/reviews/
.local-archive/

# ultra-oracle consult verdict output (skip-ultra-oracle.local already covered by *.local globs)
.claude/ultra-oracle/
# Legacy oracle-max artifacts — keep ignored so pre-rename verdict files (which may
# contain ChatGPT prompt/design content) don't become unignored after upgrading.
.claude/oracle-max/

# codex-goal-handover run artifacts (per-iter logs, verifier outputs, result JSONs)
# New runs go to ${TMPDIR:-/tmp}/codex-goal-runs/ (see codex-goal-handover SKILL.md);
# this entry still covers legacy artifacts written under the old in-repo path.
scripts/codex/.runs/

# Antigravity (agy) CLI per-project state (project-id symlinks back to ~/.gemini/config/)
.antigravitycli/

# CodeGraph tree-sitter index artifacts (regeneratable, per-repo)
.codegraph/

# headroom-ai local tooling state (context-compression MCP — not part of the plugin)
# Repo-root-anchored so they can't shadow same-named files/dirs at other depths.
/headroom_memory.db
/cache/

# Local agent tooling files (per-developer, not part of the plugin)
/.agents/
/WARP.md
