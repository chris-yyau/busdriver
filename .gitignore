.DS_Store
__pycache__/
*.pyc
node_modules/
sessions/
*.tmp
.worktrees/

# Test + coverage artifacts (generated by vitest / pytest)
coverage/
coverage-*.xml
.coverage
.pytest_cache/
.venv/
# uv test-run lockfile (regenerated from skills/skill-comply/pyproject.toml by `uv run`).
# Force-add it if you want reproducible test deps: git add -f skills/skill-comply/uv.lock
skills/skill-comply/uv.lock

# Local gate state (transient, session-scoped)
.claude/*.local
.claude/*.local.*
.claude/litmus-state.md
.claude/bypass-log.jsonl
.claude/review-metrics.jsonl
.claude/*.log
.claude/.gate-block-count.local
.claude/.impl-gate-block-count.local

# Claude workspace artifacts
.claude/worktrees/
AGENTS.md

# Internal planning docs and review artifacts
docs/reviews/
docs/plans/
docs/superpowers/plans/
docs/superpowers/specs/
.local-archive/

# codex-goal-handover run artifacts (per-iter logs, verifier outputs, result JSONs)
# New runs go to ${TMPDIR:-/tmp}/codex-goal-runs/ (see codex-goal-handover SKILL.md);
# this entry still covers legacy artifacts written under the old in-repo path.
scripts/codex/.runs/

# Antigravity (agy) CLI per-project state (project-id symlinks back to ~/.gemini/config/)
.antigravitycli/

# CodeGraph tree-sitter index artifacts (regeneratable, per-repo)
.codegraph/

# headroom-ai local tooling state (context-compression MCP — not part of the plugin)
# Repo-root-anchored so they can't shadow same-named files/dirs at other depths.
/headroom_memory.db
/cache/

# Local agent tooling files (per-developer, not part of the plugin)
/.agents/
/WARP.md
